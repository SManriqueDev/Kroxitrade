{
  "name": "kroxitrade",
  "displayName": "Kroxitrade",
  "version": "1.0.55",
  "license": "MIT",
  "description": "A browser extension that enhances the Path of Exile trade site with bookmarks, history and result tools.",
  "author": "KroxiLabs",
  "contributors": [
    "louisgv",
    "joacoesteban"
  ],
  "scripts": {
    "dev": "plasmo dev",
    "build:chrome": "node scripts/bump-version.cjs && plasmo build",
    "build:firefox": "npx plasmo build --target=firefox-mv2",
    "package:chrome": "npm run build:chrome && node scripts/archive-build.cjs",
    "package:firefox": "npm run build:firefox && node scripts/archive-build.cjs firefox-mv2-prod"
  },
  "dependencies": {
    "js-base64": "^3.7.8",
    "lucide-static": "^1.7.0",
    "plasmo": "latest",
    "svelte": "4.2.9",
    "svelte-preprocess": "5.1.3",
    "svgo": "^3.3.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "sass": {
    "silenceDeprecations": [
      "legacy-js-api"
    ]
  },
  "manifest": {
    "permissions": [
      "storage",
      "tabs"
    ],
    "host_permissions": [
      "https://*.pathofexile.com/*",
      "https://poe.ninja/*"
    ]
  }
}
